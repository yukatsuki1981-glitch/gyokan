# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-jwt-key

# Local dev: use localhost for OAuth redirects (optional; auto-fixes 0.0.0.0)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel: add the same variables in Project Settings → Environment Variables.
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://www.gyokan.app  (本番の実際の URL)
#   Redirect URLs:
#     https://www.gyokan.app/auth/callback
#     http://localhost:3000/auth/callback
# Vercel 本番では NEXT_PUBLIC_SITE_URL=https://www.gyokan.app も推奨
