# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-jwt-key

# Local dev: use localhost for OAuth redirects (optional; auto-fixes 0.0.0.0)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel: add the same variables in Project Settings → Environment Variables.
# 本番（gyokan.app の DNS 復旧前は vercel.app を使用）:
#   NEXT_PUBLIC_SITE_URL=https://gyokan.vercel.app
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://gyokan.vercel.app
#   Redirect URLs:
#     https://gyokan.vercel.app/auth/callback
#     https://www.gyokan.app/auth/callback  (ドメイン復旧後)
#     http://localhost:3000/auth/callback
